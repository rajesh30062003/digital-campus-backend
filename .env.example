# ─────────────────────────────────────────────────────────────────────────────
# Digital Campus Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local development:
MONGODB_URI=mongodb://127.0.0.1:27017/digital-campus

# MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/digital-campus?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production
JWT_SECRET=replace_with_a_long_random_secret_string_minimum_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

NODE_ENV=development

# ── Cloudinary (optional — file uploads) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP / Email (optional — notifications) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@digitalcampus.edu

# ── create-admin script overrides (optional) ─────────────────────────────────
ADMIN_EMAIL=admin@campus.edu
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Admin User
