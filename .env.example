# ==============================================================================
# DIGITAL CAMPUS ERP - BACKEND ENVIRONMENT CONFIGURATION
# ==============================================================================

# ── 1. SERVER & RUNTIME CONFIGURATION ─────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Client Application URL for CORS Authorization
CLIENT_URL=https://your-frontend.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# ── 2. DATABASE CONFIGURATION (MongoDB Atlas or Self-Hosted Replica Set) ─────
MONGODB_URI=mongodb+srv://admin:secure_pass_2026@cluster0.example.mongodb.net/digital_campus_erp?retryWrites=true&w=majority

# ── 3. SECURITY & CRYPTOGRAPHY ────────────────────────────────────────────────
# Secret used for signing JWT access and refresh tokens (Min 32 characters)
JWT_SECRET=production_jwt_super_secret_signing_key_2026_digital_campus_erp_v2

# AES-256-GCM symmetric key for data encryption & disaster recovery backups (Exact 32 bytes)
ENCRYPTION_KEY=a_32_byte_secret_key_for_aes_256_gcm!

# ── 4. AI & INTELLIGENCE ENGINE ───────────────────────────────────────────────
# Google Gemini API key for clinical AI differential diagnosis & institutional assistant
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── 5. EMAIL & NOTIFICATIONS (Optional SMTP Configuration) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@campus.edu
SMTP_PASS=your_app_specific_password

# ── 6. CLOUDINARY FILE STORAGE (Optional) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── 7. PAYMENT GATEWAY (Optional Razorpay / Stripe Integration) ───────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
